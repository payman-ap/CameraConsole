          <string notr="true">QSlider::groove:horizontal {
    border: 1px solid #2a2d32;
    height: 6px;
    background: #1e2126;
    border-radius: 3px;
}
QSlider::sub-page:horizontal {
    background: #38bdf8; /* Colored volume bar up to the handle */
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #cbd5e1;
    border: 1px solid #2a2d32;
    width: 14px;
    margin-top: -4px;
    margin-bottom: -4px;
    border-radius: 7px;
}
QSlider::handle:horizontal:hover {
    background: #ffffff;
    border-color: #38bdf8;
}</string>
